    --checkout shorthand=none type=bool default="false" usage="write a doc template (prefilled from TITLE and anchor/label flags) to an editable file and print its path"
    --commit shorthand=none type=stringArray default="[]" usage="commit anchor (repeatable)"
    --dir shorthand=none type=stringArray default="[]" usage="directory anchor (repeatable)"
    --json shorthand=none type=bool default="false" usage="emit JSON"
    --label shorthand=none type=stringArray default="[]" usage="label (repeatable)"
    --path shorthand=none type=stringArray default="[]" usage="path anchor (repeatable)"
    --when shorthand=none type=string default="" usage="free-text read-this-when trigger"
  inherited:
    (none)

